---
interface Props{
	name: string;
	role: string;
	email?: string;
	phone?: string;
	website?: string;
}
const { name, role, email = null, phone = null, website = null } = Astro.props;
---
<div class="flex flex-col gap-[4px] border-1 border-primary rounded-lg px-[8px] pt-[8px] pb-[16px] w-xs h-2xl">
	<p class="text-secondary">{role}</p>
	<h3 class="text-2xl font-medium">{name}</h3>
	<hr class="h-[1px] border-0 bg-secondary" />
	<div class="flex flex-row gap-[8px]">
		<p>Email:</p><a class="underline text-secondary hover:text-primary" href={email}
			>{email}</a
		>
	</div>
	<div class="flex flex-row gap-[8px]">
		<p>Phone:</p><a class="underline text-secondary hover:text-primary" href={phone}
			>{phone}</a
		>
	</div>
	<div class="flex flex-row gap-[8px]">
		<p>Website:</p><a class="underline text-secondary hover:text-primary" href={website}
			>{website}</a
		>
	</div>
</div>
